<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Container for Fragments/Views -->
    <FrameLayout
        android:id="@+id/main_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Default Home View (Map + Search) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/home_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Full Screen Map -->
            <org.osmdroid.views.MapView
                android:id="@+id/map"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Top Bar Overlay -->
            <LinearLayout
                android:id="@+id/top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp"
                android:gravity="center_vertical"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Greetings, Passenger!"
                        android:textColor="#000000"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        app:fontFamily="@font/gsans" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find buses across Sri Lanka"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:alpha="0.7"
                        app:fontFamily="@font/gsans" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_notifications"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_notifications"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- Search Overlay Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/search_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="12dp"
                app:layout_constraintTop_toBottomOf="@+id/top_bar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/et_start_location"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/edit_text_background"
                        android:hint="Starting point"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:textSize="14sp"
                        app:fontFamily="@font/gsans" />

                    <EditText
                        android:id="@+id/et_destination"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/edit_text_background"
                        android:hint="Where to?"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:textSize="14sp"
                        app:fontFamily="@font/gsans" />

                    <EditText
                        android:id="@+id/et_bus_no"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/edit_text_background"
                        android:hint="Bus Number (Optional)"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:textSize="14sp"
                        app:fontFamily="@font/gsans" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_search_route"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_background"
                        android:text="Search"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        app:fontFamily="@font/gsans" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- News View (Hidden by default) -->
        <include layout="@layout/fragment_news"
            android:id="@+id/news_view"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Premium Floating Navigation Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/floating_nav_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="35dp"
        app:cardElevation="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_container"
            android:layout_width="wrap_content"
            android:layout_height="70dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:animateLayoutChanges="true">

            <!-- Home Pill -->
            <LinearLayout
                android:id="@+id/nav_home_pill"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:background="@drawable/nav_pill_selected"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_nav_home"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_home"
                    app:tint="#000000" />

                <TextView
                    android:id="@+id/tv_nav_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:visibility="visible"
                    app:fontFamily="@font/gsans" />
            </LinearLayout>

            <!-- News Pill -->
            <LinearLayout
                android:id="@+id/nav_news_pill"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_nav_news"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_bus_news"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_nav_news"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="News"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    app:fontFamily="@font/gsans" />
            </LinearLayout>

            <!-- Schedule Pill -->
            <LinearLayout
                android:id="@+id/nav_schedule_pill"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_nav_schedule"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_bus_schedule"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_nav_schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    app:fontFamily="@font/gsans" />
            </LinearLayout>

            <!-- Profile Pill -->
            <LinearLayout
                android:id="@+id/nav_profile_pill"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_nav_profile"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_lost_found"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_nav_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    app:fontFamily="@font/gsans" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
